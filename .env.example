# Optional. Raises the GitHub Search API rate limit from 10 to 30 req/min.
# Create a fine-grained token with public read access at:
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional. Enables the Product Hunt source. Free developer token:
# https://www.producthunt.com/v2/oauth/applications  (use the "Developer Token")
PRODUCT_HUNT_TOKEN=

# Optional. Microsoft Clarity analytics (session heatmaps/recordings). Create a
# project at https://clarity.microsoft.com and paste its project id. Only loads
# in production builds.
NEXT_PUBLIC_CLARITY_ID=

# Optional. PostHog product analytics. Public project token + host from your
# PostHog project settings. Only loads in production builds.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sources with no config needed: Hacker News, Lobsters, Dev.to.
